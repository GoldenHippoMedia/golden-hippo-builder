{
  "name": "@goldenhippo/builder-funnel-angular",
  "version": "0.1.0",
  "type": "module",
  "description": "Angular integration SDK for Golden Hippo Builder.io funnels — typed content fetching, routing helpers, and re-exported schemas",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./content": {
      "import": {
        "types": "./dist/content/index.d.ts",
        "default": "./dist/content/index.js"
      },
      "require": {
        "types": "./dist/content/index.d.cts",
        "default": "./dist/content/index.cjs"
      }
    },
    "./routing": {
      "import": {
        "types": "./dist/routing/index.d.ts",
        "default": "./dist/routing/index.js"
      },
      "require": {
        "types": "./dist/routing/index.d.cts",
        "default": "./dist/routing/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoldenHippoMedia/golden-hippo-builder.git",
    "directory": "packages/builder-funnel-angular"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@goldenhippo/builder-funnel-schemas": "*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "nx": {
    "tags": [
      "scope:funnel",
      "type:integration"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
